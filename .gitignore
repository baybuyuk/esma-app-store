# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# local-only Claude Code overrides
.claude/settings.local.json

# build artifacts
files.zip
build-output.log
crash.log

# ikon/grafik kaynak dosyalari (sadece islenmis cikti assets/'a girer)
/icon/
icon.zip

# yedek dosyalar (git zaten versiyonluyor)
*.bak
*.havasbak
*_bak

# gecici cikti dizini (ajan/refactor outputs)
/tmp/

# kaynak materyal (esma havas PDF'leri — repoyu şişirir)
esma-pdf/

# kapak/referans gorseller (root'a birakilan, repoya gitmesin)
/*.JPG
/*.jpg
/*.jpeg
/maxresdefault.*

# kisisel multi-agent prompts (her gelistirici kendi seti)
hu-agents/

# Fastlane gizlileri (Play Console service account, asla commit etme!)
fastlane/play-key.json
fastlane/report.xml
fastlane/README.md

# Build aab/apk (build artifact)
*.aab
*.apk
