{
  "expo": {
    "name": "Hu",
    "slug": "hu-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F5EE"
    },
    "ios": {
      "bundleIdentifier": "com.baybuyukk.huapp",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Namaz vakitlerini ve kıble yönünü konumunuza göre hesaplamak için kullanılır.",
        "NSMotionUsageDescription": "Kıble yönünü gösterebilmek için pusula sensörü kullanılır."
      }
    },
    "android": {
      "package": "com.baybuyukk.huapp",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F5EE"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Namaz vakitlerini ve kıble yönünü konumunuza göre hesaplamak için kullanılır."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#B08D2E",
          "sounds": [
            "./assets/sounds/ezan.mp3"
          ]
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "9f8280df-6a70-4dd8-bb04-90641e896b86"
      }
    },
    "owner": "baybuyukk"
  }
}
